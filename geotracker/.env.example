# ============================================
# Application Environment
# ============================================
NODE_ENV=development
PORT=4000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geotrackr

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Authentication Secrets
# NOTE: Change these to strong random values in production
# Generate with: openssl rand -base64 32
# ============================================
JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ============================================
# Frontend URLs
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Tracking Domain Configuration
# ============================================
TRACKING_DOMAIN_HOST=localhost
TRACKING_DOMAIN_SCHEME=http

# ============================================
# Registration Promo Code (Optional)
# Leave empty to require approval for all registrations
# ============================================
PROMO_CODE=
