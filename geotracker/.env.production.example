# Production Environment Configuration
# =========================================
# Copy this file to .env.local and fill in the actual values
# NEVER commit sensitive values to version control

# Application
NODE_ENV=production
PORT=4000

# Database (use a managed service like RDS, Azure Database, etc. in production)
DATABASE_URL=postgresql://username:password@hostname:5432/geotrackr

# Redis (use a managed service like ElastiCache, Azure Cache for Redis, etc. in production)
REDIS_URL=redis://:password@hostname:6379

# JWT Secrets (IMPORTANT: Generate strong random values)
# Run: openssl rand -base64 32
JWT_ACCESS_SECRET=your_access_secret_here_change_this
JWT_REFRESH_SECRET=your_refresh_secret_here_change_this
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# URLs
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Tracking Domain
TRACKING_DOMAIN_HOST=yourdomain.com
TRACKING_DOMAIN_SCHEME=https

# Optional: Promo code for registration (leave empty to require manual approval)
PROMO_CODE=

# Database credentials for docker-compose (if using Docker)
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Redis password (if using password-protected Redis)
REDIS_PASSWORD=your_redis_password_here
