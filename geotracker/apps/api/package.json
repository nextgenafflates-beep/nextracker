    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@types/bcrypt": "5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
